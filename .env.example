# Copy to .env and fill in. For local dev, `supabase start` provides the DB URL below.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Embeddings (optional). Empty = deterministic matcher + Postgres full-text fallback (no key needed).
# "gateway" enables pgvector semantic retrieval (vector(1536), text-embedding-3-small)
# via the Vercel AI Gateway — auth is OIDC / AI_GATEWAY_API_KEY, no provider key in code.
EMBEDDINGS_PROVIDER=

# NL→SQL query engine (optional). Empty = curated matcher only (no key needed).
# "gateway" routes SQL generation through the Vercel AI Gateway (OIDC / AI_GATEWAY_API_KEY).
QUERY_PROVIDER=
# QUERY_MODEL=anthropic/claude-haiku-4.5

# Least-privilege DB role generated SQL runs as (migration 0002 creates it; applied
# by `supabase db reset`). Defaults to "query_reader"; set empty to disable and rely
# on the app-layer table allowlist alone.
# QUERY_DB_ROLE=query_reader

# Ingestion knobs (script-time only — `pnpm ingest` / .github/workflows/ingest.yml).
# ANAC_YEARS=2024,2025      # year window for the heavy ANAC national zips (~75 MB/year)
# INGEST_CONCURRENCY=4      # max sources ingested in parallel
# INGEST_FORCE=             # 1 = override a count-guard `drop` (an `empty` always blocks)
# INGEST_STALE_DAYS=7       # ingest exits non-zero if a source's last ok run is older than this
