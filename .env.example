# Copy to .env and fill in. For local dev, `supabase start` provides the DB URL below.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Embeddings (optional). Empty = deterministic matcher + Postgres full-text fallback (no key needed).
# "openai" + OPENAI_API_KEY enables pgvector semantic retrieval (vector(1536), text-embedding-3-small).
EMBEDDINGS_PROVIDER=
OPENAI_API_KEY=
